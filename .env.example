# ── Server ────────────────────────────────────────────────────────────────
PORT=3000

# ── MongoDB ───────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://admin:admin@localhost:27017/sky_mall_db?authSource=admin

# ── PostgreSQL (use PG_CONNECTION_STRING for a single DSN, or individual vars)
# PG_CONNECTION_STRING=postgresql://postgres:postgres@localhost:5432/ecommerce_scraper
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=ecommerce_scraper
PG_USER=postgres
PG_PASSWORD=postgres

# ── API Authentication (leave empty to disable) ──────────────────────────
API_KEY=

# ── CAPTCHA auto-solving (https://2captcha.com) ──────────────────────────
CAPTCHA_API_KEY=

# ── CNY → USD exchange rate ───────────────────────────────────────────────
CNY_TO_USD_RATE=0.1376

# ── Webhook notifications (optional) ──────────────────────────────────────
# Global webhook URL — receives POST for job.completed, job.failed, price.drop
# WEBHOOK_URL=https://hooks.slack.com/services/xxx or https://your-server.com/webhook

# ── Proxy rotation (optional) ────────────────────────────────────────────
#
# Option 1: Rotating Gateway (recommended)
# A single endpoint where the provider rotates IPs for you.
# Works with: Smartproxy, Bright Data, Oxylabs, IPRoyal, 922proxy, etc.
# PROXY_GATEWAY=http://user:pass@gate.smartproxy.com:7777
# PROXY_GATEWAY_STICKY=false   # true = same IP per scraping job (session ID in username)
# PROXY_GATEWAY_STICKY_TEMPLATE={username}-session-{session}
# PROXY_GATEWAY_STICKY_MINUTES=15
#
# 1024proxy sticky example:
# PROXY_GATEWAY=http://user-region-HK:pass@us.1024proxy.io:3000
# PROXY_GATEWAY_STICKY=true
# PROXY_GATEWAY_STICKY_TEMPLATE={username}-sid-{session}-t-{minutes}
# PROXY_GATEWAY_STICKY_MINUTES=15
#
# Option 2: Static proxy pool (you manage the rotation)
# Comma-separated list of proxies
# PROXY_LIST=http://user:pass@host1:port,socks5://user:pass@host2:port
# Or path to a file with one proxy per line
# PROXY_FILE=/path/to/proxies.txt
# Or simply create a proxies.txt file in the project root
#
# You can also add/remove proxies at runtime via the API or UI (Sessions tab).
